{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "esnext", //? es6
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "jsx": "react-jsx", // jsx- чтобы не импортировать реакт в компоненты
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@appFirebase": ["./firebase.js"],
      "@app/*": ["./src/app/*"],
      "@entities/*": ["./src/entities/*"],
      "@pages/*": ["./src/pages/*"],
      "@features/*": ["./src/features/*"],
      "@shared/*": ["./src/shared/*"],
      "@widgets/*": ["./src/widgets/*"],

      "@creating/*": ["./src/pages/creating/*"],
      "@selecting/*": ["./src/widgets/selecting/*"],
      "@editing/*": ["./src/pages/editing/*"],
      "@questionnaire/*": ["./src/pages/questionnaire/*"],
      "@lib/*": ["./src/shared/chadcn/lib/*"],
      "@ui/*": ["./src/shared/chadcn/ui/*"],
      "@store/*": ["./src/store/*"],
      "@reducers/*": ["./src/store/reducers/*"],
      "@utils/*": ["./src/shared/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "firebase.js"],
  "exclude": ["node_modules", "dist"]
}
